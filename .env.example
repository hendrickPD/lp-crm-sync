# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real credentials.

# Affinity API key — generate at Settings → API in your Affinity workspace.
# Treat like a password. Workspace-scoped by default.
AFFINITY_API_KEY=

# Slack channel ID (not name) for the raw LP meeting notes channel.
# Find it by opening the channel in Slack web and copying the trailing ID from the URL,
# e.g. https://yourworkspace.slack.com/archives/GRKEM91EK → GRKEM91EK
LP_NOTES_CHANNEL_ID=

# Slack channel ID for the feedback/report channel where the skill posts top-10 reports
# and reads "go" approvals / corrections.
LP_CRM_CHANNEL_ID=

# Numeric Affinity list ID for your LP pipeline list.
# To find it:  curl -s https://api.affinity.co/lists -H "Authorization: Bearer $AFFINITY_API_KEY"
# then pick the list whose name matches your LP tracker and copy its `id`.
AFFINITY_LP_LIST_ID=

# Optional: your Slack workspace subdomain, used for building permalinks in reports.
# e.g. if your workspace is at https://yourco.slack.com, set this to "yourco"
SLACK_WORKSPACE_DOMAIN=
